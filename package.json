{
    "name": "collectdb",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "format": "prettier --write \"data/**/*.yaml\"",
        "format:check": "prettier --cache --check \"data/**/*.yaml\"",
        "pr:prepare": "npm run format && npm run snag && npm run index && npm run reference-of && npm run validate:data",
        "pr:check": "npm run format:check && npm run snag -- --check && npm run index -- --check && npm run reference-of -- --check && npm run validate:data",
        "index": "tsx scripts/index.ts",
        "sheets-sync": "tsx scripts/sheets-sync.ts",
        "validate:data": "tsx scripts/validate-data.ts",
        "snag": "tsx scripts/snag.ts",
        "reference-of": "tsx scripts/reference-of.ts"
    },
    "dependencies": {
        "dotenv": "^16.6.1",
        "googleapis": "^150.0.1",
        "uuid": "^13.0.0",
        "yaml": "^2.8.1",
        "yargs": "^18.0.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^22.15.29",
        "@types/yargs": "^17.0.35",
        "prettier": "^3.8.3",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}